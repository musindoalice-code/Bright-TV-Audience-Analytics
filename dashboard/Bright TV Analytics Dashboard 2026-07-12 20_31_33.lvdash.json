{
  "datasets": [
    {
      "name": "fdeae5cb",
      "displayName": "bright_tv_userprofiles",
      "config": {
        "version": "1.1",
        "source": "workspace.default.bright_tv_userprofiles",
        "dimensions": [
          {
            "name": "UserID",
            "expr": "source.UserID",
            "displayName": "User ID"
          },
          {
            "name": "Name",
            "expr": "source.Name",
            "displayName": "Name"
          },
          {
            "name": "Surname",
            "expr": "source.Surname",
            "displayName": "Surname"
          },
          {
            "name": "Email",
            "expr": "source.Email",
            "displayName": "Email"
          },
          {
            "name": "Gender",
            "expr": "source.Gender",
            "displayName": "Gender"
          },
          {
            "name": "Race",
            "expr": "source.Race",
            "displayName": "Race"
          },
          {
            "name": "Age",
            "expr": "source.Age",
            "displayName": "Age"
          },
          {
            "name": "Province",
            "expr": "source.Province",
            "displayName": "Province"
          },
          {
            "name": "Social Media Handle",
            "expr": "source.`Social Media Handle`",
            "displayName": "Social Media Handle"
          }
        ],
        "measures": [
          {
            "name": "count",
            "expr": "COUNT(*)",
            "comment": "Represents the total number of rows in the dataset. Use this measure to count all",
            "displayName": "Count"
          }
        ]
      }
    },
    {
      "name": "5b54ed10",
      "displayName": "bright_tv_viewership",
      "config": {
        "version": "1.1",
        "source": "workspace.default.bright_tv_viewership",
        "dimensions": [
          {
            "name": "UserID0",
            "expr": "source.UserID0",
            "displayName": "User ID"
          },
          {
            "name": "Channel2",
            "expr": "source.Channel2",
            "displayName": "Channel"
          },
          {
            "name": "RecordDate2",
            "expr": "source.RecordDate2",
            "displayName": "Record Date"
          },
          {
            "name": "userid4",
            "expr": "source.userid4",
            "displayName": "Userid 4"
          },
          {
            "name": "ViewMonth",
            "expr": "DATE_TRUNC('MONTH', source.RecordDate2)",
            "displayName": "View Month"
          },
          {
            "name": "ViewDate",
            "expr": "DATE_TRUNC('DAY', source.RecordDate2)",
            "displayName": "View Date"
          }
        ],
        "measures": [
          {
            "name": "total_views",
            "expr": "COUNT(*)",
            "displayName": "Total Views"
          },
          {
            "name": "unique_users",
            "expr": "COUNT(DISTINCT source.UserID0)",
            "displayName": "Unique Users"
          }
        ]
      }
    }
  ],
